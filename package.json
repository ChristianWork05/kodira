{
  "name": "kodira",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "dotenv -e .env -- turbo dev",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down -v",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier . --check",
    "format:write": "prettier . --write"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "prettier": "^3.6.2",
    "turbo": "^2.5.4",
    "typescript": "^5.9.2"
  }
}
