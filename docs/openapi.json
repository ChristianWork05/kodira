  "components": {
    "securitySchemes": {
      "bearer": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    },
    "schemas": {
      "HealthStatus": { "type": "string", "enum": ["ok", "degraded"] },
      "HealthDependencyStatus": { "type": "string", "enum": ["up", "down"] },
      "HealthResponseDto": {
        "type": "object",
        "properties": {
          "status": { "$ref": "#/components/schemas/HealthStatus" },
          "db": { "$ref": "#/components/schemas/HealthDependencyStatus" },
          "redis": { "$ref": "#/components/schemas/HealthDependencyStatus" }
        },
        "required": ["status", "db", "redis"]
      },
      "OkResponseDto": {
        "type": "object",
        "properties": { "ok": { "type": "boolean" } },
        "required": ["ok"]
      },
      "UserRole": { "type": "string", "enum": ["student", "instructor", "mentor", "admin"] },
      "UserMeDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "email": { "type": "string" },
          "username": { "type": "string" },
          "fullName": { "type": "string", "nullable": true },
          "avatarUrl": { "type": "string", "nullable": true },
          "bio": { "type": "string", "nullable": true },
          "roles": { "type": "array", "items": { "$ref": "#/components/schemas/UserRole" } },
          "emailVerified": { "type": "boolean" },
          "preferredLanguage": { "type": "string", "nullable": true },
          "timezone": { "type": "string", "nullable": true },
          "country": { "type": "string", "nullable": true },
          "xp": { "type": "number" },
          "currentStreak": { "type": "number" },
          "referralCode": { "type": "string" },
          "referralCredits": { "type": "number" },
          "isActive": { "type": "boolean" },
          "lastLoginAt": { "type": "string", "nullable": true },
          "createdAt": { "type": "string" },
          "updatedAt": { "type": "string" }
        },
        "required": [
          "id",
          "email",
          "username",
          "roles",
          "emailVerified",
          "xp",
          "currentStreak",
          "referralCode",
          "referralCredits",
          "isActive",
          "createdAt",
          "updatedAt"
        ]
      },
      "PublicUserProfileDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "username": { "type": "string" },
          "fullName": { "type": "string", "nullable": true },
          "avatarUrl": { "type": "string", "nullable": true },
          "bio": { "type": "string", "nullable": true },
          "roles": { "type": "array", "items": { "$ref": "#/components/schemas/UserRole" } },
          "xp": { "type": "number" },
          "currentStreak": { "type": "number" },
          "createdAt": { "type": "string" }
        },
        "required": ["id", "username", "roles", "xp", "currentStreak", "createdAt"]
      },
      "UpdateMyProfileDto": {
        "type": "object",
        "properties": {
          "username": { "type": "string" },
          "fullName": { "type": "string", "nullable": true },
          "avatarUrl": { "type": "string", "nullable": true },
          "bio": { "type": "string", "nullable": true },
          "preferredLanguage": { "type": "string", "nullable": true },
          "timezone": { "type": "string", "nullable": true },
          "country": { "type": "string", "nullable": true }
        }
      },
      "AuthTokensDto": {
        "type": "object",
        "properties": {
          "tokenType": { "type": "string", "enum": ["Bearer"] },
          "accessToken": { "type": "string" },
          "refreshToken": { "type": "string" },
          "accessTokenExpiresInSeconds": { "type": "number" }
        },
        "required": [
          "tokenType",
          "accessToken",
          "refreshToken",
          "accessTokenExpiresInSeconds"
        ]
      },
      "AuthResponseDto": {
        "type": "object",
        "properties": {
          "tokens": { "$ref": "#/components/schemas/AuthTokensDto" },
          "user": { "$ref": "#/components/schemas/UserMeDto" }
        },
        "required": ["tokens", "user"]
      },
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": { "type": "string" },
          "password": { "type": "string" },
