  "info": {
    "title": "KODIRA API",
    "description": "",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "HealthResponseDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "ok",
            "description": "ok | degraded"
          },
          "db": {
            "type": "string",
            "example": "up",
            "description": "up | down"
          },
          "redis": {
            "type": "string",
            "example": "up",
            "description": "up | down"
          }
        },
        "required": [
          "status",
          "db",
          "redis"
        ]
      },
      "UserMeDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "example": "user@mail.com"
          },
          "username": {
            "type": "string",
            "example": "kodi_dev"
          },
          "fullName": {
            "type": "object",
            "nullable": true
          },
          "avatarUrl": {
            "type": "object",
            "nullable": true
          },
          "bio": {
            "type": "object",
            "nullable": true
          },
          "roles": {
            "example": [
              "student"
            ],
            "type": "array",
            "items": {
              "type": "array"
            }
          },
          "emailVerified": {
            "type": "boolean",
            "example": false
          },
          "preferredLanguage": {
            "type": "object",
            "nullable": true
          },
          "timezone": {
            "type": "object",
            "nullable": true
          },
          "country": {
            "type": "object",
            "nullable": true
          },
          "xp": {
            "type": "number",
            "example": 0
          },
          "currentStreak": {
            "type": "number",
            "example": 0
          },
          "referralCode": {
            "type": "string",
            "example": "AB12CD34"
          },
          "referralCredits": {
            "type": "number",
            "example": 0
          },
          "isActive": {
            "type": "boolean",
            "example": true
          },
          "lastLoginAt": {
            "type": "object",
            "nullable": true
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "email",
          "username",
          "fullName",
          "avatarUrl",
          "bio",
          "roles",
          "emailVerified",
          "preferredLanguage",
          "timezone",
          "country",
          "xp",
          "currentStreak",
          "referralCode",
          "referralCredits",
          "isActive",
          "lastLoginAt",
          "createdAt",
          "updatedAt"
        ]
      },
      "UpdateMyProfileDto": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "description": "Username único (min 3, max 20). Se normaliza a minúsculas."
          },
          "fullName": {
            "type": "object",
            "nullable": true
          },
          "avatarUrl": {
            "type": "object",
            "nullable": true
          },
          "bio": {
            "type": "object",
            "nullable": true
          },
          "preferredLanguage": {
            "type": "object",
            "nullable": true
          },
          "timezone": {
            "type": "object",
            "nullable": true
          },
          "country": {
            "type": "object",
            "nullable": true
          }
        }
      },
      "PublicUserProfileDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "username": {
            "type": "string",
            "example": "kodi_dev"
          },
          "fullName": {
            "type": "object",
            "nullable": true
          },
          "avatarUrl": {
            "type": "object",
            "nullable": true
          },
          "bio": {
            "type": "object",
            "nullable": true
          },
          "roles": {
            "example": [
              "student"
            ],
            "type": "array",
            "items": {
              "type": "array"
            }
          },
          "xp": {
            "type": "number",
            "example": 0
          },
          "currentStreak": {
            "type": "number",
            "example": 0
          },
          "createdAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "username",
          "fullName",
          "avatarUrl",
          "bio",
          "roles",
          "xp",
          "currentStreak",
          "createdAt"
        ]
      },
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@mail.com"
          },
          "password": {
            "type": "string",
            "description": "Min 8 chars y al menos 1 número.",
            "example": "password1"
          },
          "username": {
            "type": "string",
            "example": "kodi_dev"
          },
          "fullName": {
            "type": "object",
            "nullable": true
          },
          "referralCode": {
            "type": "object",
            "nullable": true,
            "description": "Código de referido (opcional)."
          }
        },
        "required": [
          "email",
          "password",
          "username"
        ]
      },
      "AuthTokensDto": {
        "type": "object",
        "properties": {
          "tokenType": {
            "type": "string",
            "example": "Bearer"
          },
          "accessToken": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          },
          "accessTokenExpiresInSeconds": {
            "type": "number",
            "example": 900
          }
        },
        "required": [
          "tokenType",
          "accessToken",
          "refreshToken",
          "accessTokenExpiresInSeconds"
        ]
      },
      "AuthResponseDto": {
        "type": "object",
        "properties": {
          "tokens": {
            "$ref": "#/components/schemas/AuthTokensDto"
          },
          "user": {
            "$ref": "#/components/schemas/UserMeDto"
          }
        },
        "required": [
          "tokens",
          "user"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@mail.com"
          },
          "password": {
            "type": "string",
            "description": "Min 8 chars y al menos 1 número.",
            "example": "password1"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "RefreshDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string"
          }
        },
        "required": [
          "refreshToken"
        ]
      },
      "OkResponseDto": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": true
          }
        },
        "required": [
          "ok"
        ]
      },
      "ForgotPasswordDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@mail.com"
          }
        },
        "required": [
          "email"
        ]
      },
      "ResetPasswordDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "newPassword": {
            "type": "string",
            "description": "Min 8 chars y al menos 1 número.",
            "example": "newpass1"
          }
        },
        "required": [
          "token",
          "newPassword"
        ]
      },
      "VerifyEmailDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          }
        },
        "required": [
          "token"
        ]
      }
    }
  }
}